PROJECT_NAME=Risk-Adaptive Railway Crossing Protection System
PROJECT_SHORT_NAME=Smart Railway Crossing Anomaly Prevention System
APP_VERSION=0.1.2
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_PREFIX=/api

# Linux / Docker (default superuser: postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_railway_crossing_db

# macOS Homebrew — uncomment and comment the line above if postgres role does not exist:
# DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/smart_railway_crossing_db
